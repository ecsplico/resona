# Environment Configuration Template
# Copy this file to .env and fill in your values

# ── ws-engine (:7001) ────────────────────────────────────────────────
# Optional: if set, clients must send X-API-Key: <value>
# ENGINE_API_KEY=your_engine_key_here

# ASR backend: "faster-whisper" (default), "whisper", "transformer"
ASR_MODE=faster-whisper
DEFAULT_FASTWHISPER_MODEL=large-v3

# CORS origins for the engine (comma-separated, default: allow all)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── ws-api (:7000) ───────────────────────────────────────────────────
# URL of the ws-engine service (required in production)
ENGINE_URL=http://localhost:7001

# Optional: if set, clients must send X-API-Key: <value>
# WS_API_KEY=your_api_key_here

# Data directories (sensible defaults based on cwd)
# DATA_PATH=./data
# FILE_PATH=./data/files
# DB_PATH=./data/db

# ── ws-client / ws-cli ───────────────────────────────────────────────
WS_API_URL=http://localhost:7000
# WS_API_KEY=your_api_key_here

# ── ws-live / ws-ui ──────────────────────────────────────────────────
# FILE_PATH=./data/files   (recorder output directory)

# ── Logging ──────────────────────────────────────────────────────────
# LOGLEVEL=info
