# Environment Configuration Template
# Copy this file to .env and fill in your values

# ── API Security ─────────────────────────────────────────────────────
API_KEY=your_secure_api_key_here

# ── ASR Configuration ────────────────────────────────────────────────
# Mode: "faster-whisper", "whisper-tf", or "whisper"
ASR_MODE=faster-whisper
ASR_MODEL_NAME=base

# Model names per mode (only the one matching ASR_MODE is used)
DEFAULT_FASTWHISPER_MODEL=large-v3
DEFAULT_WHISPER_MODEL=base
DEFAULT_TRANSFORMER_MODEL=openai/whisper-base

# ── Audio Settings ───────────────────────────────────────────────────
# SAMPLE_RATE=44100
# CHANNELS=1

# ── Data Paths (all optional, sensible defaults used) ────────────────
# DATA_PATH=./data
# FILE_PATH=./data/files
# INBOX_PATH=./data/inbox
# MD_PATH=./data/md
# DB_PATH=./data/db

# ── Database ─────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///./data/db/jjobs.sqlite

# ── Server ───────────────────────────────────────────────────────────
# LOGLEVEL=info

# ── CORS (comma-separated origins, default: allow all) ───────────────
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080
