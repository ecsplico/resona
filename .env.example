# ─── Resona .env.example ─────────────────────────────────────────────────
# Copy this file to `.env` and fill in any non-default values.
# All variables are read via `python-decouple`'s config() (env first, then .env).
# Exception: resona-client reads RESONA_API_URL / RESONA_API_KEY via os.getenv().

# ── resona-api (port 7000) ──────────────────────────────────────────────
# Optional API key required from clients. When unset, auth is disabled.
# Set to a long random string in production.
# RESONA_API_KEY=changeme

# Comma-separated list of engine-server base URLs to probe and load-balance.
RESONA_ENGINE_URLS=http://localhost:7001

# Engine name to use for requests that omit `engine=`. Empty = first available.
# RESONA_DEFAULT_ENGINE=faster-whisper

# Root directory for all persistent data (audio files, SQLite DB, transcripts).
DATA_PATH=./data

# Per-subdir overrides (all default to <DATA_PATH>/<name>).
# FILE_PATH=./data/files
# MD_PATH=./data/md
# DB_PATH=./data/db
# RESONA_PROFILES_DIR=./data/profiles

# SQLAlchemy database URL. Defaults to sqlite under DB_PATH.
# DATABASE_URL=sqlite:///./data/db/jjobs.sqlite

# CORS origins (comma-separated). `*` allows any.
# CORS_ORIGINS=*

# Legacy: model name written into Job rows for display only.
# ASR_MODEL_NAME=unknown

# ── resona-engine-server (port 7001) ────────────────────────────────────
# Which engine plugin to load: faster-whisper | whisper | voxtral
RESONA_ENGINE=faster-whisper

# Optional API key the engine requires in X-API-Key. When unset, auth is disabled.
# Also sent by resona-api to engine-server when set.
# RESONA_ENGINE_KEY=changeme

# Engine-server port (used by `uv run resona-engine-*`).
# PORT=7001

# Default models per engine. Override to use smaller/faster models on CPU.
DEFAULT_FASTWHISPER_MODEL=large-v3
# DEFAULT_WHISPER_MODEL=large-v3
# DEFAULT_VOXTRAL_MODEL=openai/whisper-large-v3

# ── resona-client / resona CLI ──────────────────────────────────────────
# resona-api base URL the client talks to.
# RESONA_API_URL=http://localhost:7000

# ── resona-postprocess (LLM steps in profiles) ──────────────────────────
# Default litellm model for `llm` / `extract` pipeline steps.
# RESONA_LLM_MODEL=gpt-4o-mini

# Custom LLM endpoint (e.g. a local Ollama instance).
# RESONA_LLM_API_BASE=http://localhost:11434

# ── Cloud provider API keys ─────────────────────────────────────────────
# Setting any of these auto-activates the matching cloud STT/TTS provider.
# DEEPGRAM_API_KEY=
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=

# ── CLI recording / TUI ─────────────────────────────────────────────────
# Microphone capture defaults used by `resona rec` / `resona ui` / `resona live`.
# SAMPLE_RATE=44100
# CHANNELS=1

# ── Logging ─────────────────────────────────────────────────────────────
# debug | info | warning | error
LOGLEVEL=info

# ── Directus backend ─────────────────────────────────────────────
DIRECTUS_SECRET=change-me
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me
# Static service token for the transcribe worker (see directus/bootstrap.md §3)
DIRECTUS_TOKEN=

# ── directus-transcribe worker ───────────────────────────────────
TRANSCRIBE_POLL_INTERVAL=5
TRANSCRIBE_CONCURRENCY=2
TRANSCRIBE_STALE_MINUTES=15
