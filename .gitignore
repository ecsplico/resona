# ── Secrets ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime data (per-deployment; resona-api creates these on demand) ──
data/
db/
files/
md/
inbox/

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
.python-version-local

# ── Docs build output (mkdocs) ──────────────────────────────────────
site/

# ── Tooling caches ──────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.worktrees/

# ── Model caches (kept out of repo even if a user drops them in) ────
models/
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.onnx
*.ckpt

# ── IDE / editor ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Legacy ──────────────────────────────────────────────────────────
# Do NOT add `src/` here — every workspace package uses a src-layout
# (packages/*/src/ and apps/resona-cli/src/), and hatchling honors
# .gitignore at build time. An `src/` rule produces empty wheels.
whisper-*
